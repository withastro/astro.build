---
import { THEMES_API_URL } from '~/helpers/constants.ts';
import ThemeCard from './ThemeCard.astro';

interface Props {
	date?: string;
	version?: string;
	updatedBefore?: string;
}

const { date, version, updatedBefore } = Astro.props;

let url: URL;
if (date) {
	url = new URL(`/api/themes/monthly?month=${date}`, THEMES_API_URL);
} else {
	const params = new URLSearchParams();
	if (version) params.append('version', version);
	if (updatedBefore) params.append('updatedBefore', updatedBefore);
	url = new URL(`/api/themes?${params.toString()}`, THEMES_API_URL);
}

const themes = await fetch(url).then((res) => res.json());
---

<ul
	class="grid gap-5 !p-0 md:grid-flow-row-dense md:grid-cols-2 lg:-mx-16 lg:!mb-16 lg:!mt-8 lg:grid-cols-3 xl:-mx-32"
>
	{themes.map((theme: any) => <ThemeCard {...theme} />)}
</ul>
