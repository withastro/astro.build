---
import { THEMES_API_URL } from '~/helpers/constants.ts';
import ThemeCard from './ThemeCard.astro';

interface Props {
	date: string;
	excluded: [];
}

const allThemes = await fetch(
	new URL(`/api/themes/monthly?month=${Astro.props.date}`, THEMES_API_URL),
).then((res) => res.json());

const excluded = Astro.props.excluded;
const slugs = allThemes.map((theme) => theme.Theme.slug);
const themeSlugs = slugs.filter((slug) => !excluded.includes(slug));
const themes = allThemes.filter((theme) => themeSlugs.includes(theme.Theme.slug));
---

<ul
	class="grid gap-5 !p-0 md:grid-flow-row-dense md:grid-cols-2 lg:-mx-16 lg:!mb-16 lg:!mt-8 lg:grid-cols-3 xl:-mx-32"
>
	{themes.map((theme: any) => <ThemeCard {...theme} />)}
</ul>
