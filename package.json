{
	"name": "@example/minimal",
	"type": "module",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"lint": "biome lint",
		"format": "pnpm run format:code && pnpm run format:imports",
		"format:code": "biome format --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --linter-enabled=false --write",
		"format-unsafe": "biome check --write --unsafe",
		"typecheck": "astro check",
		"update:integrations": "node -r dotenv/config ./scripts/update-integrations.mjs",
		"update:showcase": "node -r dotenv/config ./scripts/update-showcase.mjs",
		"update:stats": "node ./scripts/update-stats.mjs"
	},
	"dependencies": {
		"@astro-community/astro-embed-youtube": "^0.5.10",
		"@astrojs/check": "0.9.9",
		"@astrojs/compiler-rs": "^0.2.2",
		"@astrojs/mdx": "7.0.0-beta.3",
		"@astrojs/netlify": "8.0.0-beta.1",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.3",
		"@astrojs/tailwind": "^6.0.2",
		"@biomejs/biome": "2.4.16",
		"@netlify/plugin-lighthouse": "^6.0.4",
		"@preact/signals-core": "^1.14.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@types/node": "^24.13.1",
		"astro": "7.0.0-beta.6",
		"astro-embed": "^0.13.0",
		"astro-expressive-code": "^0.43.1",
		"astro-icon": "^1.1.5",
		"chart.js": "4.4.8",
		"date-fns": "^4.4.0",
		"dotenv": "^17.4.2",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1",
		"sharp": "^0.34.5",
		"smartypants": "^0.2.2",
		"tailwindcss": "^3.4.19",
		"typescript": "^6.0.3",
		"xss": "^1.0.15"
	},
	"devDependencies": {
		"@actions/core": "^3.0.1",
		"@octokit/graphql": "^7.1.1",
		"@playwright/test": "^1.60.0",
		"linkedom": "^0.18.12",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-to-string": "^4.0.0",
		"p-limit": "^7.3.0",
		"p-retry": "^8.0.0",
		"yaml": "^2.9.0"
	},
	"packageManager": "pnpm@11.5.2"
}
