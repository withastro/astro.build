{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "astro-build",
	"compatibility_date": "2025-05-13",
	// Don't expose the *.workers.dev URLs; the site is served via its custom domain.
	"workers_dev": false,
	"preview_urls": false,
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},
	"r2_buckets": [
		{
			"bucket_name": "site-assets",
			"binding": "site_assets",
		},
	],
}
